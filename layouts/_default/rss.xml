{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if eq .Title .Site.Title }}{{ .Site.Title }}{{ else }}{{ with .Title }}{{ . }} on {{ end }}{{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent content {{ if ne .Title .Site.Title }}in {{ .Title }} {{ end }}on {{ .Site.Title }}</description>
    <generator>Hugo</generator>
    {{ with .Site.LanguageCode }}<language>{{ . }}</language>{{ end }}
    {{ if not .Date.IsZero }}<lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>{{ end }}
    {{ with .OutputFormats.Get "RSS" }}{{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}{{ end }}
    <image>
      <url>{{ .Site.BaseURL | strings.TrimRight "/" }}/images/ed.png</url>
      <title>{{ .Site.Title }}</title>
      <link>{{ .Site.BaseURL }}</link>
    </image>
    {{ $pages := .Pages }}
    {{ if .IsHome }}{{ $pages = where .Site.RegularPages "Section" "in" (slice "posts" "notes" "links" "reading") }}{{ end }}
    {{ $feedPath := .RelPermalink | strings.TrimRight "/" }}
    {{ if eq $feedPath "" }}{{ $feedPath = "global (everything)" }}{{ end }}
    {{ range where $pages ".Date.IsZero" false }}
    <item>
      <title>{{ if .Params.link }}→ {{ end }}{{ if .Title }}{{ .Title }}{{ else }}{{ .Content | plainify | truncate 60 "..." }}{{ end }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      {{ $permalink := .Permalink -}}
      {{ $desc := .Content | replaceRE ` data-lang="[^"]*"` "" | replaceRE ` loading="[^"]*"` "" | replaceRE `href="#([^"]*)"` (printf `href="%s#$1"` $permalink) -}}
      {{ $bookmarkLink := "" -}}
      {{ with .Params.link -}}
        {{ $bookmarkLink = printf "<p><a href=\"%s\">%s</a></p>" . . -}}
      {{ end -}}
      {{ $footer := printf `<hr><p><small>You're getting this because you follow my <strong>%s</strong> feed — if you'd like to filter what comes through, you can find all my feeds at <a href="https://edleeman.co.uk/rss">edleeman.co.uk/rss</a>. Regardless, thanks for reading over RSS. You're awesome and I appreciate you.</small></p>` $feedPath -}}
      <description>{{ with $bookmarkLink }}{{ . | html }}{{ end }}{{ with .Params.description }}{{ . | html }}{{ else }}{{ with .Description }}{{ . | html }}{{ else }}{{ if .IsPage }}{{ $desc | html }}{{ end }}{{ end }}{{ end }}{{ $footer | html }}</description>
    </item>
    {{ end }}
  </channel>
</rss>
